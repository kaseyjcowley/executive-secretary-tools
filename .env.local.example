# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (create app at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Only this email address will be allowed to sign in
ALLOWED_EMAIL=

# Internal route IP whitelist (comma-separated IPs)
INTERNAL_ALLOWED_IPS=

# Cron job bearer token (keep for API cron endpoints)
CRON_SECRET=
